<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dr Chinnadurai R - Critical Care Specialist</title>
  <style>
    body { margin:0; font-family: 'Segoe UI', sans-serif; background:#f4f7fb; color:#222; }

    /* HERO */
    .hero {
      background: linear-gradient(rgba(10,61,98,0.85), rgba(30,144,255,0.85)), url('https://images.unsplash.com/photo-1581595219315-a187dd40c322');
      background-size: cover;
      background-position: center;
      color: white;
      padding: 80px 20px;
    }

    .hero-content {
      max-width: 1100px;
      margin: auto;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 30px;
    }

    .hero img {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      object-fit: cover;
      border: 5px solid white;
    }

    .hero-text h1 { margin:0; font-size:36px; }
    .hero-text p { margin:8px 0; font-size:18px; }

    .cta-btn {
      margin-top: 15px;
      background:#00c853;
      color:white;
      padding:12px 20px;
      border:none;
      border-radius:8px;
      font-size:16px;
      cursor:pointer;
    }

    .container { max-width:1100px; margin:auto; padding:20px; }

    .section {
      background:white;
      padding:25px;
      margin:20px 0;
      border-radius:12px;
      box-shadow:0 6px 20px rgba(0,0,0,0.06);
    }

    h2 { color:#0a3d62; margin-bottom:10px; }

    .profile {
      display:flex;
      flex-wrap:wrap;
      gap:25px;
      align-items:center;
    }

    .profile img {
      width:220px;
      border-radius:12px;
    }

    .grid {
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
      gap:15px;
    }

    .card {
      background:#f8fbff;
      padding:15px;
      border-radius:10px;
      border-left:4px solid #1e90ff;
    }

    ul { padding-left:20px; }
    li { margin:8px 0; }

    footer {
      text-align:center;
      padding:20px;
      background:#0a3d62;
      color:white;
    }
  </style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <div class="hero-content">
    <img src="doctor.jpg" alt="Dr Chinnadurai R">
    <div class="hero-text">
      <h1>Dr Chinnadurai R</h1>
      <p>South Bangalore’s Leading Critical Care Physician</p>
      <p>Expert in ICU, Life Support & Emergency Medicine</p>
      <button class="cta-btn">Call Now</button>
    </div>
  </div>
</div>

<div class="container">

  <!-- PROFILE -->
  <div class="section">
    <h2>Doctor Profile</h2>
    <div class="profile">
      <img src="doctor.jpg" alt="Doctor Profile">
      <div>
        <p>
          Dr Chinnadurai R is a highly respected Critical Care Specialist with extensive experience in managing complex ICU cases, life-threatening emergencies, and multi-organ failure conditions.
        </p>
        <p>
          Known for precision, rapid response, and compassionate care, he is trusted by both patients and medical professionals across South Bangalore.
        </p>
      </div>
    </div>
  </div>

  <!-- QUALIFICATIONS -->
  <div class="section">
    <h2>Qualifications & Credentials</h2>
    <ul>
      <li>MD / DNB in Critical Care / Internal Medicine</li>
      <li>Advanced Training in Intensive Care Medicine</li>
      <li>Certified in Mechanical Ventilation & ECMO</li>
      <li>Member of National & International Critical Care Societies</li>
    </ul>
  </div>

  <!-- EXPERTISE -->
  <div class="section">
    <h2>Areas of Expertise</h2>
    <div class="grid">
      <div class="card">Mechanical Ventilation & ECMO</div>
      <div class="card">Septic Shock & Multi-Organ Failure</div>
      <div class="card">Cardiac & Hemodynamic Monitoring</div>
      <div class="card">ARDS & Respiratory Failure</div>
      <div class="card">CRRT / SLED Dialysis</div>
      <div class="card">Neuro Critical Care</div>
    </div>
  </div>

  <!-- TRUST -->
  <div class="section">
    <h2>Why Choose Dr Chinnadurai R</h2>
    <ul>
      <li>Proven expertise in high-risk ICU cases</li>
      <li>Evidence-based and ethical medical care</li>
      <li>Strong multidisciplinary collaboration</li>
      <li>Focus on patient recovery and outcomes</li>
    </ul>
  </div>

  <!-- CONTACT -->
  <div class="section">
    <h2>Contact & Location</h2>
    <p>
      KIMS Hospitals, Electronic City<br>
      Bengaluru, Karnataka<br>
      24/7 ICU & Emergency Support Available
    </p>
  </div>

</div>

<footer>
  <p>© 2026 Dr Chinnadurai R | Critical Care Specialist</p>
</footer>

</body>
</html>
